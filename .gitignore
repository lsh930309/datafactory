# Runtime / local environment
.env/
.venv/
.venv-ocr/
.cache/
.playwright-browsers/
.pytest_cache/
__pycache__/
*.py[cod]
.DS_Store

# Local orchestration / scratch / backups
.bin/
.omx/
.codeboarding/
tmp/

# Frontend build/dependencies
web/node_modules/
web/dist/

# Generated outputs and heavy document samples
outputs/
seed_samples/
handwriting/

# Workbench: keep JSON state, exclude heavy source/render artifacts
workbench/.trash/
workbench/**/samples/
workbench/**/samples/**
workbench/**/inpaint/
workbench/**/inpaint/**
workbench/**/cleanup/
workbench/**/cleanup/**
# Generated authoring previews / preview-like verification runs
workbench/**/authoring/render_preview*/
workbench/**/authoring/render_preview*/**
workbench/**/*.png
workbench/**/*.jpg
workbench/**/*.jpeg
workbench/**/*.webp
workbench/**/*.tif
workbench/**/*.tiff
workbench/**/*.bmp
workbench/**/*.pdf

# Generated visual assets are intentionally not committed.
assets/**
!assets/.gitkeep
!assets/cleanroom_generated/.gitkeep
!assets/logo_pool/.gitkeep
!assets/map_pool/.gitkeep
!assets/photo_pool/.gitkeep

# External/local fonts are user-provided runtime assets.
fonts/**
!fonts/.gitkeep

# Playwright CLI logs
.playwright-cli/

# OCR intermediate results are reproducible and may contain source-derived text.
workbench/**/ocr/
workbench/**/ocr/**
workbench/**/ocr_recrop/
workbench/**/ocr_recrop/**
# Generated authoring previews (regenerable UI artifacts)
workbench/**/authoring/live_preview/**
# Handwriting print/scan runtime outputs are reproducible and may contain scanned/source-derived data.
workbench/handwriting_scan_uploads/
workbench/handwriting_scan_intake/
workbench/**/handwriting_pipeline/print_packs/
workbench/**/handwriting_pipeline/scanned_intake/
# Local authoring backups are preserved on disk but not committed.
workbench/**/authoring/backups/**
# Local review backups are preserved on disk but not committed.
workbench/**/review/**/backups/**
# Agent request visual sidecars are regenerable and may be large/source-derived.
workbench/**/authoring/agent_requests/**/visual_evidence/**
# Agent run execution logs may contain local prompt/runtime context; keep job.json only.
workbench/**/authoring/agent_runs/**/stdout.log
workbench/**/authoring/agent_runs/**/stderr.log
workbench/**/authoring/agent_runs/**/codex_exec_prompt.md
workbench/**/authoring/agent_runs/**/codex_last_message.md
workbench/**/authoring/agent_runs/**/generation_log.json
workbench/**/authoring/agent_runs/**/*
!workbench/**/authoring/agent_runs/**/
!workbench/**/authoring/agent_runs/**/job.json
