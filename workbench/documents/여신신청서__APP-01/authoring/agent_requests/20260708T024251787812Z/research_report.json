  "doc_id": "APP-01",
  "title": "여신신청서",
  "queries": [
    "여신신청서 작성 방법 대출 신청서 신청금액 자금용도 상환계획 담보",
    "여신거래 신청서 양식 대출금액 자금용도 담보 보증인",
    "은행여신거래기본약관 담보 보증인",
    "대출거래약정서 대출금액 이자율 담보 보증인"
  ],
  "sources": [
    {
      "evidence_id": "R1",
      "url": "https://www.law.go.kr/법령/은행법",
      "source_type": "official_law_search_target",
      "summary": "은행의 여신/대출 업무가 금융기관 업무 맥락에 속한다는 일반 배경 확인용. 템플릿에 없는 필드는 추가하지 않았다."
    },
    {
      "evidence_id": "R2",
      "url": "https://www.kfb.or.kr/",
      "source_type": "industry_association_search_target",
      "summary": "은행권 여신거래 관행과 약정/신청 문서 용어 확인을 위한 보조 출처로 사용. 신청구분, 대출과목, 금액, 기한, 이율 등은 템플릿 가시 라벨과 결합해 해석했다."
    },
    {
      "evidence_id": "R3",
      "url": "https://www.fss.or.kr/",
      "source_type": "public_financial_supervisor_search_target",
      "summary": "금융 문서의 확인/승인/설명 책임 맥락 보조. 결재/감사/서명 영역은 실제 템플릿 시각 근거와 사용자 지시를 우선했다."
    },
    {
      "evidence_id": "R4",
      "url": "https://www.smes.go.kr/",
      "source_type": "public_business_support_search_target",
      "summary": "기업 정보 항목(업체명, 대표자, 주소, 설립일자, 주생산품, 종업원수, 재무항목)의 일반 사업자/기업 개요 맥락 보조."
    },
    {
      "evidence_id": "R5",
      "url": "https://www.kodit.co.kr/",
      "source_type": "public_credit_guarantee_institution_search_target",
      "summary": "기업금융의 담보, 보증, 보전 방법 관련 용어 보조. 채권보전 표의 담보/보증인 항목 해석에만 제한적으로 반영했다."
    }
  ],
