  "field_rules": {
    "patient_rrn": {
      "rule": "person.rrn",
      "note": "유효 생년월일과 뒷자리 마스킹은 renderer 구현 확인이 필요하며, age_from_rrn으로 나이 관계를 강제한다."
    },
    "patient_age": {
      "rule": "pattern:##",
      "note": "전체 이미지에서 만( )세가 정적으로 인쇄되어 숫자만 렌더링한다."
    },
    "diagnosis_1_name": {
      "rule": "free_text.short",
      "note": "pick_record가 KCD 진단명과 코드를 동일 레코드로 덮어쓴다."
    },
    "admission_discharge_period": {
      "rule": "free_text.short",
      "note": "pick_record가 한 셀용 입원/퇴원 복합 문자열을 덮어쓴다."
    },
    "issue_year": {
      "rule": "date.year",
      "note": "정적 년 표기를 제외하고 분리 날짜 constraint를 적용한다."
    },
    "issue_month": {
      "rule": "date.month",
      "note": "정적 월 표기를 제외하고 분리 날짜 constraint를 적용한다."
    },
    "issue_day": {
      "rule": "date.day",
      "note": "정적 일 표기를 제외하고 분리 날짜 constraint를 적용한다."
    },
    "doctor_license_number": {
      "rule": "pattern:######",
      "note": "정적 제/호를 제외하고 숫자만 렌더링한다."
    }
  },
  "privacy_policy": "모든 값은 합성 예시이며 실제 환자·의사·기관의 식별정보로 사용하지 않는다.",
