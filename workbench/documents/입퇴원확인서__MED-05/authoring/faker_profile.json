  "field_rules": {
    "patient_address": {
      "rule": "address.ko",
      "note": "상세 주소는 층/호 또는 건물명/호까지 포함하되 소괄호를 쓰지 않는다."
    },
    "medical_institution_name": {
      "rule": "medical.institution_ko",
      "note": "일반 기업명이 아니라 병원/의원/요양병원 등 의료기관 명칭으로 생성한다."
    },
    "patient_age": {
      "rule": "pattern:## + age_from_rrn",
      "note": "최종 값은 age_from_rrn constraint가 주민등록번호와 발급일자를 기준으로 덮어쓴다."
    },
    "admission_discharge_period": {
      "rule": "pool:admission_period_labels + pick_record",
      "note": "렌더링은 '입원: yyyy-mm-dd, 퇴원: yyyy-mm-dd' 형식이며 primary schema에는 입원일/퇴원일을 분리 저장한다."
    },
    "doctor_opinion": {
      "rule": "pool:doctor_opinions",
      "note": "입원 치료 경과, 퇴원 후 외래 추적, 안정 권고 등 실제 확인서에 들어갈 수 있는 문장을 사용한다."
    },
    "remarks": {
      "rule": "pool:remarks",
      "note": "제출용도/기록 근거/추가 확인 등 다양한 비고 문구를 사용한다."
    },
    "issue_year": {
      "rule": "date.year + date_not_before",
      "note": "발급일자 연월일은 date_group으로 유효 날짜를 만든 뒤 date_not_before로 퇴원일보다 과거가 되지 않게 보정한다."
    },
    "issue_month": {
      "rule": "date.month + date_not_before",
      "note": "발급일자 연월일은 date_group으로 유효 날짜를 만든 뒤 date_not_before로 퇴원일보다 과거가 되지 않게 보정한다."
    },
    "issue_day": {
      "rule": "date.day + date_not_before",
      "note": "발급일자 연월일은 date_group으로 유효 날짜를 만든 뒤 date_not_before로 퇴원일보다 과거가 되지 않게 보정한다."
    }
  },
