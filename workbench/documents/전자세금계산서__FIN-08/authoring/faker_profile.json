  "relationship_model": {
    "version": 1,
    "strategy": "renderer_supported_constraints_only",
    "rules": [
      "supplier_* fields are selected from one supplier_records object",
      "recipient_* fields are selected from one recipient_records object",
      "issue_date and lineN_month/day are selected from one transaction_date_sets object",
      "line item amount records precompute quantity * unit_price = supply_amount and tax_amount = supply_amount * 10%",
      "summary_supply_amount = sum(line1..line4 supply_amount)",
      "summary_tax_amount = sum(line1..line4 tax_amount)",
      "total_amount = summary_supply_amount + summary_tax_amount",
      "cash_amount = total_amount, check/promissory_note/receivable amount cells are rendered as 0 by default"
    ]
  }
