  "field_rules": [
    {"field_id":"investment_risk_grade_label","rule":"literal:투자 위험 등급","evidence_ids":["RISK-GRADE-01"],"note":"전체 이미지에서 표제 자체가 값 anchor에 포함되어 고정 표제로 생성한다."},
    {"field_id":"investment_risk_grade","rule":"choice:1~6등급","evidence_ids":["RISK-GRADE-01"],"note":"협회 기준의 최소 6단계를 사용하고 record constraint가 펀드 레코드와 함께 최종값을 선택한다."},
    {"field_id":"fund_name","rule":"free_text.short","evidence_ids":["DART-FUND-01"],"note":"실제 최종값은 fund_cover_records의 합성 펀드명으로 덮어쓴다."},
    {"field_id":"asset_manager_name","rule":"company.name_ko","evidence_ids":["DART-FUND-01"],"note":"실제 최종값은 펀드 레코드와 짝지어진 합성 운용사명으로 덮어쓴다."},
    {"field_id":"disclosure_reference_text","rule":"free_text.short","evidence_ids":["DART-FUND-01"],"note":"오인을 막기 위해 합성 운용사 URL은 예약 도메인 example.invalid를 사용한다."},
    {"field_id":"prospectus_preparation_date","rule":"date.kr","evidence_ids":["CAPITAL-MARKETS-ACT-01"],"note":"전체 이미지상 정적 연월일 접미사가 없으므로 날짜 전체를 생성하며 효력발생일 이전, 기준일 이하로 제한한다."},
    {"field_id":"securities_registration_effective_date","rule":"date.kr","evidence_ids":["CAPITAL-MARKETS-ACT-01","DART-FUND-01"],"note":"작성기준일 이후 0~60일, 기준일 이하로 제한한다."},
    {"field_id":"offered_security_type","rule":"choice:법적 형태 4종","evidence_ids":["DART-FUND-01"],"note":"레코드에서는 현재 표지 형태에 맞춰 투자신탁 수익증권을 사용한다."},
    {"field_id":"offering_total_amount","rule":"free_text.short","evidence_ids":["DART-FUND-01"],"note":"anchor가 대괄호·라벨·좌 단위를 모두 포함하므로 완성된 복합 문자열을 record에서 제공한다."},
    {"field_id":"offering_period_description","rule":"free_text.short","evidence_ids":["CAPITAL-MARKETS-ACT-01","DART-FUND-01"],"note":"개방형 계속모집 문구의 합성 변형을 record에서 제공한다."}
  ]
}
